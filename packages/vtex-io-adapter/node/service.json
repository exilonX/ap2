{
  "memory": 256,
  "timeout": 10,
  "minReplicas": 2,
  "maxReplicas": 10,
  "workers": 4,
  "routes": {
    "search": {
      "path": "/_v/acg/search",
      "public": true
    },
    "productDetail": {
      "path": "/_v/acg/product/:sku",
      "public": true
    },
    "getCart": {
      "path": "/_v/acg/cart",
      "public": true
    },
    "addToCart": {
      "path": "/_v/acg/cart/items",
      "public": true
    },
    "removeFromCart": {
      "path": "/_v/acg/cart/items/:sku",
      "public": true
    },
    "updateCartItem": {
      "path": "/_v/acg/cart/items/update",
      "public": true
    },
    "setCustomerProfile": {
      "path": "/_v/acg/cart/profile",
      "public": true
    },
    "setShippingAddress": {
      "path": "/_v/acg/cart/shipping",
      "public": true
    },
    "getShippingOptions": {
      "path": "/_v/acg/cart/shipping-options",
      "public": true
    },
    "applyCoupon": {
      "path": "/_v/acg/cart/coupon",
      "public": true
    },
    "proposeDeal": {
      "path": "/_v/acg/intelligence/propose-deal",
      "public": true
    },
    "initiateCheckout": {
      "path": "/_v/acg/checkout/initiate",
      "public": true
    },
    "checkoutRedirect": {
      "path": "/_v/acg/checkout/redirect/:sessionId",
      "public": true
    },
    "paymentPage": {
      "path": "/_v/acg/checkout/pay/:sessionId",
      "public": true
    },
    "executeCheckout": {
      "path": "/_v/acg/checkout/execute/:sessionId",
      "public": true
    },
    "orderStatus": {
      "path": "/_v/acg/orders/:orderId",
      "public": true
    },
    "didDocument": {
      "path": "/_v/acg/.well-known/did.json",
      "public": true
    }
  }
}
