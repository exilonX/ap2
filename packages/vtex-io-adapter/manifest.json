{
  "name": "acg-adapter",
  "vendor": "vtexeurope",
  "version": "0.0.2",
  "title": "Agent Commerce Gateway Adapter",
  "description": "VTEX IO adapter for AI agent commerce operations",
  "mustUpdateAt": "2025-01-01",
  "categories": [],
  "dependencies": {},
  "builders": {
    "node": "7.x"
  },
  "credentialType": "absolute",
  "settingsSchema": {
    "title": "ACG Adapter Settings",
    "type": "object",
    "properties": {
      "llmProvider": {
        "title": "LLM Provider",
        "description": "Which AI provider to use for the chat assistant",
        "type": "string",
        "enum": ["claude", "openai", "gemini"],
        "default": "claude"
      },
      "claudeApiKey": {
        "title": "Claude API Key",
        "description": "Anthropic API key (starts with sk-ant-)",
        "type": "string"
      },
      "claudeModel": {
        "title": "Claude Model",
        "description": "Model ID (default: claude-haiku-4-5-20251001)",
        "type": "string",
        "default": "claude-haiku-4-5-20251001"
      },
      "openaiApiKey": {
        "title": "OpenAI API Key",
        "description": "OpenAI API key (starts with sk-). Also used for embeddings.",
        "type": "string"
      },
      "openaiModel": {
        "title": "OpenAI Model",
        "description": "Model ID (default: gpt-4o-mini)",
        "type": "string",
        "default": "gpt-4o-mini"
      },
      "geminiApiKey": {
        "title": "Gemini API Key",
        "description": "Google AI Studio API key",
        "type": "string"
      },
      "geminiModel": {
        "title": "Gemini Model",
        "description": "Model ID (default: gemini-2.5-flash)",
        "type": "string",
        "default": "gemini-2.5-flash"
      },
      "pineconeApiKey": {
        "title": "Pinecone API Key",
        "description": "Pinecone API key for vector store",
        "type": "string"
      },
      "pineconeIndexHost": {
        "title": "Pinecone Index Host",
        "description": "Pinecone index host (e.g., acg-products-xxxxx.svc.aped-1234.pinecone.io)",
        "type": "string"
      },
      "acgAllowedOrigins": {
        "title": "Allowed origins (CORS)",
        "description": "List of origins permitted to call /_v/acg/* from a browser. Storefront URLs only. Empty list denies all browser callers.",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "acgAuthToken": {
        "title": "Server-to-server auth token",
        "description": "Shared secret callers must send as X-ACG-Auth-Token. Used by the MCP server (no Origin). Generate any 32+ character random string. Empty disables the secret path.",
        "type": "string"
      },
      "acgRateLimits": {
        "title": "Rate limits per route class",
        "description": "Override the default per-IP rate limits. Each class accepts perMinute and perDay numbers. Defaults: chat 20/200, mutating 30/500, read 60/2000.",
        "type": "object",
        "properties": {
          "chat": {
            "type": "object",
            "properties": {
              "perMinute": {
                "type": "number"
              },
              "perDay": {
                "type": "number"
              }
            }
          },
          "mutating": {
            "type": "object",
            "properties": {
              "perMinute": {
                "type": "number"
              },
              "perDay": {
                "type": "number"
              }
            }
          },
          "read": {
            "type": "object",
            "properties": {
              "perMinute": {
                "type": "number"
              },
              "perDay": {
                "type": "number"
              }
            }
          }
        }
      },
      "acgSessionDailyLimit": {
        "title": "Per-session daily request cap",
        "description": "Max requests per orderForm (chat session) over 24h. Catches runaway sessions even from allowlisted origins. Default: 100.",
        "type": "number",
        "default": 100
      }
    }
  },
  "policies": [
    {
      "name": "outbound-access",
      "attrs": {
        "host": "{{account}}.vtexcommercestable.com.br",
        "path": "*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.anthropic.com",
        "path": "/v1/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.openai.com",
        "path": "/v1/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "generativelanguage.googleapis.com",
        "path": "/v1beta/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "*.pinecone.io",
        "path": "/*"
      }
    },
    {
      "name": "vbase-read-write"
    },
    {
      "name": "colossus-write-logs"
    }
  ],
  "$schema": "https://raw.githubusercontent.com/vtex/node-vtex-api/master/gen/manifest.schema"
}
