{
  "name": "@acg/mcp-server",
  "version": "0.0.1",
  "description": "MCP Server for Agent Commerce Gateway - connects Claude to VTEX",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:apps",
    "copy:apps": "node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','apps'),d=p.join('dist','apps');fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.html'))fs.copyFileSync(p.join(s,f),p.join(d,f));\"",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts"
  },
  "dependencies": {
    "@acg/core": "file:../core",
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.13.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
