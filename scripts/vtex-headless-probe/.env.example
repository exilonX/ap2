# Required: which VTEX merchant the probe hits.
VTEX_ACCOUNT=vtexeurope

# Required: the SKU id to add to the cart. Make sure it has stock + a non-zero
# sellingPrice on this account, or step 2 (add item) will silently insert a
# 0-quantity line and the flow will fail downstream.
SKU=1

# Required: email for the client profile. Use a guest email that is NOT in
# the merchant's customer database, otherwise CHK0087 fires (VTEX requires
# auth to associate a new address with an existing customer).
EMAIL=demo@test.ro

# Required for step 9 (authorize-transaction). The /pvt/ endpoint demands
# merchant credentials. Without these the probe stops after step 8 with a
# clear message and an orderGroup you can verify in admin.
VTEX_APP_KEY=
VTEX_APP_TOKEN=

# Optional: payment system to set on step 6.
# 47 = Cash on this account. List by inspecting step 5's response.
PAYMENT_SYSTEM_ID=47

# Optional: shipping address overrides.
#
# Defaults to a CEP proven to resolve to a non-empty geoCoordinates in
# vtexeurope's RO postal-code DB (417571 / Adoni / BIHOR). Bucharest CEPs
# like "010101" are NOT in the DB; using them makes VTEX silently return
# geoCoordinates=[], which then shows as a divergence against any
# reference order.
#
# If you change POSTAL_CODE, confirm it exists in the merchant's RO data
# first — otherwise expect the empty-coords symptom to come back.
POSTAL_CODE=417571
CITY=Adoni
STATE=BIHOR
COUNTRY=ROU
STREET=nucilor
NUMBER=2
# Leave NEIGHBORHOOD unset to match the reference order (where it
# persists as null). Set it explicitly to test address with neighborhood.
# NEIGHBORHOOD=Sector 1
