              ]
            },
            "description": "Get existing orderForm by ID.\n\nThis is the main cart object with items, totals, shipping, payment data."
          },
          "response": []
        },
        {
          "name": "Add Items to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderItems\": [\n    {\n      \"id\": \"123456\",\n      \"quantity\": 1,\n      \"seller\": \"1\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}/items",
              "protocol": "https",
