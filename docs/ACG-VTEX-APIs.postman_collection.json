    {
      "name": "Payment Gateway",
      "description": "Payment gateway APIs (vtexpayments.com.br)",
      "item": [
        {
          "name": "Step 7: Send Payment Details",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"paymentSystem\": 2,\n    \"paymentSystemName\": \"Visa\",\n    \"group\": \"creditCard\",\n    \"installments\": 1,\n    \"installmentsInterestRate\": 0,\n    \"installmentsValue\": 10000,\n    \"value\": 10000,\n    \"referenceValue\": 10000,\n    \"fields\": {\n      \"holderName\": \"JOHN DOE\",\n      \"cardNumber\": \"4111111111111111\",\n      \"validationCode\": \"123\",\n      \"dueDate\": \"12/28\"\n    },\n    \"transaction\": {\n      \"id\": \"{{transactionId}}\",\n      \"merchantName\": \"{{account}}\"\n    }\n  }\n]"
            },
            "url": {
              "raw": "https://{{account}}.vtexpayments.com.br/api/pub/transactions/{{transactionId}}/payments",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexpayments",
                "com",
                "br"
              ],
              "path": [
                "api",
                "pub",
                "transactions",
                "{{transactionId}}",
                "payments"
              ]
            },
            "description": "Send credit card details to the payment gateway.\n\nIMPORTANT: This is where actual card data goes, NOT in the checkout API.\n\nfields:\n- holderName: Name on card (uppercase)\n- cardNumber: Full card number\n- validationCode: CVV\n- dueDate: MM/YY format"
          },
          "response": []
        },
        {
          "name": "Step 8: Authorize Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"softDescriptor\": \"ACG Purchase\",\n  \"prepareForRecurrency\": false,\n  \"split\": [],\n  \"callbackUrl\": \"\",\n  \"orderId\": \"{{orderId}}\"\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexpayments.com.br/api/pvt/transactions/{{transactionId}}/authorization-request",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexpayments",
                "com",
                "br"
              ],
              "path": [
                "api",
                "pvt",
                "transactions",
                "{{transactionId}}",
                "authorization-request"
              ]
            },
            "description": "Authorize the payment transaction.\n\nThis is the FINAL step that actually processes the payment.\n\nNote: This endpoint is /pvt/ (private) and requires app credentials."
          },
          "response": []
        }
      ]
    },
