{
  "info": {
    "name": "ACG - VTEX APIs",
    "description": "All VTEX APIs used by the Agent Commerce Gateway (ACG) adapter.\n\nSet the following variables:\n- {{account}}: Your VTEX account name (e.g., vtexeurope)\n- {{vtexAppKey}}: Your VTEX App Key\n- {{vtexAppToken}}: Your VTEX App Token\n- {{vtexIdClientAutCookie}}: VtexIdclientAutCookie value (for authenticated requests)\n- {{orderFormId}}: OrderForm ID (cart ID) - obtained from Create OrderForm\n- {{transactionId}}: Transaction ID - obtained from Place Order",
    "_postman_id": "acg-vtex-apis-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-VTEX-API-AppKey",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{vtexAppKey}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "account",
      "value": "vtexeurope",
      "type": "string"
    },
    {
      "key": "vtexAppKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "vtexAppToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "vtexIdClientAutCookie",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderFormId",
      "value": "",
      "type": "string"
    },
    {
      "key": "transactionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Search / Catalog",
      "description": "Product search and catalog APIs",
      "item": [
        {
          "name": "Search Products (by keyword)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/catalog_system/pub/products/search/rochita?_from=0&_to=4",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "catalog_system",
                "pub",
                "products",
                "search",
                "rochita"
              ],
              "query": [
                {
                  "key": "_from",
                  "value": "0",
                  "description": "Start index (0-based)"
                },
                {
                  "key": "_to",
                  "value": "4",
                  "description": "End index (0-based, inclusive)"
                }
              ]
            },
            "description": "Search products by keyword. Replace 'rochita' with your search term.\n\nReturns array of VTEXProduct objects with full product and SKU details."
          },
          "response": []
        },
        {
          "name": "Get Product by SKU",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/catalog_system/pub/products/search?fq=skuId:123456",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "catalog_system",
                "pub",
                "products",
                "search"
              ],
              "query": [
                {
                  "key": "fq",
                  "value": "skuId:123456",
                  "description": "Filter by SKU ID"
                }
              ]
            },
            "description": "Get product details by SKU ID. Replace '123456' with actual SKU.\n\nReturns array with single VTEXProduct."
          },
          "response": []
        },
        {
          "name": "Search Products (with filters)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/catalog_system/pub/products/search?fq=C:/1/&fq=P:[100 TO 500]&_from=0&_to=9",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "catalog_system",
                "pub",
                "products",
                "search"
              ],
              "query": [
                {
                  "key": "fq",
                  "value": "C:/1/",
                  "description": "Filter by category ID"
                },
                {
                  "key": "fq",
                  "value": "P:[100 TO 500]",
                  "description": "Filter by price range (in cents)"
                },
                {
                  "key": "_from",
                  "value": "0"
                },
                {
                  "key": "_to",
                  "value": "9"
                }
              ]
            },
            "description": "Search with filters: category, price range, etc."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cart (OrderForm)",
      "description": "Cart/OrderForm management APIs",
      "item": [
        {
          "name": "Create OrderForm (New Cart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.orderFormId) {",
                  "    pm.collectionVariables.set('orderFormId', jsonData.orderFormId);",
                  "    console.log('Set orderFormId:', jsonData.orderFormId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
                "orderForm"
              ]
            },
            "description": "Create a new empty orderForm (cart).\n\nAutomatically saves the orderFormId to collection variables."
          },
          "response": []
        },
        {
          "name": "Get OrderForm",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
                "orderForm",
