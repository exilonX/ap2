              "raw": "{\n  \"orderItems\": [\n    {\n      \"index\": 0,\n      \"quantity\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}/items/update",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
