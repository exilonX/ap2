    {
      "name": "Checkout Flow",
      "description": "Headless checkout flow steps (3-6)",
      "item": [
        {
          "name": "Step 3: Add Client Profile Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"documentType\": \"cpf\",\n  \"document\": \"12345678900\",\n  \"phone\": \"+5511999999999\",\n  \"isCorporate\": false\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}/attachments/clientProfileData",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
                "orderForm",
                "{{orderFormId}}",
                "attachments",
                "clientProfileData"
              ]
            },
            "description": "Add customer profile data to the order.\n\nRequired fields:\n- email\n- firstName\n- lastName\n\nOptional:\n- documentType (cpf, cnpj, etc.)\n- document\n- phone\n- isCorporate"
          },
          "response": []
        },
        {
          "name": "Step 4: Add Shipping Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clearAddressIfPostalCodeNotFound\": false,\n  \"selectedAddresses\": [\n    {\n      \"addressType\": \"residential\",\n      \"receiverName\": \"John Doe\",\n      \"postalCode\": \"01310-100\",\n      \"city\": \"São Paulo\",\n      \"state\": \"SP\",\n      \"country\": \"BRA\",\n      \"street\": \"Av. Paulista\",\n      \"number\": \"1000\",\n      \"neighborhood\": \"Bela Vista\",\n      \"complement\": \"Apt 101\"\n    }\n  ],\n  \"logisticsInfo\": [\n    {\n      \"itemIndex\": 0,\n      \"selectedSla\": \"Normal\",\n      \"selectedDeliveryChannel\": \"delivery\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}/attachments/shippingData",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
                "orderForm",
                "{{orderFormId}}",
                "attachments",
                "shippingData"
              ]
            },
            "description": "Add shipping address and logistics info.\n\nRequired in selectedAddresses:\n- addressType (residential, commercial, etc.)\n- receiverName\n- postalCode, city, state, country\n- street, number, neighborhood\n\nlogisticsInfo must have one entry per cart item:\n- itemIndex: 0-based index\n- selectedSla: Shipping option (from orderForm.shippingData.logisticsInfo[].slas)"
          },
          "response": []
        },
        {
          "name": "Step 5: Add Payment Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payments\": [\n    {\n      \"paymentSystem\": 2,\n      \"installments\": 1,\n      \"referenceValue\": 10000,\n      \"value\": 10000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://{{account}}.vtexcommercestable.com.br/api/checkout/pub/orderForm/{{orderFormId}}/attachments/paymentData",
              "protocol": "https",
              "host": [
                "{{account}}",
                "vtexcommercestable",
                "com",
                "br"
              ],
              "path": [
                "api",
                "checkout",
                "pub",
                "orderForm",
                "{{orderFormId}}",
                "attachments",
                "paymentData"
              ]
            },
            "description": "Add payment configuration.\n\nCommon paymentSystem values:\n- 1: Promissory (Boleto)\n- 2: Visa\n- 4: Mastercard\n- 6: American Express\n\nNote: Card details are NOT sent here - they go to the payments gateway."
          },
          "response": []
        },
        {
          "name": "Step 6: Place Order (Create Transaction)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.transactionData && jsonData.transactionData.merchantTransactions) {",
                  "    var transactionId = jsonData.transactionData.merchantTransactions[0].transactionId;",
                  "    pm.collectionVariables.set('transactionId', transactionId);",
                  "    console.log('Set transactionId:', transactionId);",
                  "}",
                  "if (jsonData.orders && jsonData.orders[0]) {",
                  "    pm.collectionVariables.set('orderId', jsonData.orders[0].orderId);",
                  "    console.log('Set orderId:', jsonData.orders[0].orderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-VTEX-API-AppKey",
                "value": "{{vtexAppKey}}",
                "type": "text"
              },
              {
                "key": "X-VTEX-API-AppToken",
                "value": "{{vtexAppToken}}",
                "type": "text"
              },
              {
                "key": "VtexIdclientAutCookie",
                "value": "{{vtexIdClientAutCookie}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
