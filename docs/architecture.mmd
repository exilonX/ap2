flowchart TD

subgraph group_surfaces["Distribution Surfaces"]
  node_widget["Chat Widget<br/>react pixel app"]
  node_mcp_server["MCP Server"]
end

subgraph group_adapter["VTEX IO Adapter (Merchant Endpoint)"]
  node_service_routes["Service & Routes<br/>Service entrypoint + middleware<br/>[index.ts]"]
  node_chat_handler["Chat Handler<br/>LLM tool-call loop<br/>[chat.ts]"]
  node_agent_tools["AgentTool Registry<br/>AP2 ceremony tool surface"]
  node_cart_module["Cart Module<br/>VTEX OrderForm wrapper<br/>[cart.ts]"]
  node_rest_handlers["REST Handlers"]
  node_profile_config["Profile Config<br/>per-merchant ClientConfig"]
  node_llm_client["LLM Client<br/>[llm.ts]"]
end

subgraph group_ap2["AP2 Ceremony"]
  node_merchant_identity["MerchantIdentity<br/>narrow signing surface"]
  node_vbase_keystore["VBaseKeyStore<br/>[vbase-keystore.ts]"]
  node_mandate_orch["MandateOrchestration"]
  node_payment_orch["PaymentOrchestration<br/>PaymentMandate + Receipt ceremony"]
  node_mock_cp["Mock Credentials Provider<br/>PaymentMandate user_authorization signer"]
  node_mock_network["Mock Payment Network<br/>[payment-network.ts]"]
end

subgraph group_core["@acg/core (Spec Primitives)"]
  node_core_mandates["Mandate / Receipt Factories"]
  node_core_jcs_did["JCS · Ed25519 · DID<br/>spec primitives"]
  node_core_keystore["KeyStore Interface<br/>storage seam<br/>[keystore.ts]"]
end

subgraph group_discovery["Discovery / RAG"]
  node_rag_handler["Semantic Search<br/>[rag.ts]"]
  node_sync_catalog["Bulk Catalog Sync<br/>standalone Node script"]
end

subgraph group_external["External Services"]
  node_vbase[("VTEX VBase<br/>key-value store")]
  node_vtex_apis{{"VTEX Commerce APIs<br/>checkout, catalog, OMS"}}
  node_llm_apis{{"LLM Providers"}}
  node_pinecone{{"Pinecone<br/>vector index"}}
end

node_shared_types["Shared Types<br/>cross-process DTOs"]
node_verifier(("Public Verifier"))

node_widget -->|"HTTPS /_v/acg/*"| node_service_routes
node_mcp_server -->|"HTTPS + X-ACG-Auth-Token"| node_service_routes
node_service_routes -->|"POST /chat"| node_chat_handler
node_service_routes -->|"cart · checkout · payment · did"| node_rest_handlers
node_service_routes -->|"GET /config"| node_profile_config
node_chat_handler -->|"tool-call loop"| node_llm_client
node_chat_handler -->|"dispatch AP2 tools"| node_agent_tools
node_chat_handler -->|"cart ops (legacy switch)"| node_cart_module
node_chat_handler -->|"semantic search"| node_rag_handler
node_chat_handler -.->|"system prompt + starters"| node_profile_config
node_agent_tools -->|"create_cart_mandate"| node_mandate_orch
node_agent_tools -->|"execute_payment"| node_payment_orch
node_rest_handlers --> node_cart_module
node_rest_handlers -->|"sign + verify"| node_mandate_orch
node_rest_handlers -->|"execute payment"| node_payment_orch
node_cart_module -->|"OrderForm CRUD"| node_vtex_apis
node_llm_client -->|"chat + tools"| node_llm_apis
node_mandate_orch -->|"signCartMandate"| node_merchant_identity
node_mandate_orch -.->|"create + verify + drift"| node_core_mandates
node_mandate_orch -->|"acg-mandates bucket"| node_vbase
node_payment_orch -->|"merchant DID + pubkey"| node_merchant_identity
node_payment_orch -->|"signPaymentMandate"| node_mock_cp
node_payment_orch -->|"approvePayment (7 checks)"| node_mock_network
node_payment_orch -->|"payment-mandates · receipts"| node_vbase
node_merchant_identity --> node_vbase_keystore
node_merchant_identity -.->|"createCartMandate"| node_core_mandates
node_mock_cp -->|"acg-mock-cp bucket"| node_vbase_keystore
node_mock_cp -.->|"createPaymentMandate"| node_core_mandates
node_mock_network -->|"acg-mock-network bucket"| node_vbase_keystore
node_mock_network -.->|"createPaymentReceipt + verify"| node_core_mandates
node_vbase_keystore -.->|"implements"| node_core_keystore
node_vbase_keystore --> node_vbase
node_core_mandates -.->|"JCS + Ed25519"| node_core_jcs_did
node_rag_handler -->|"query embeddings"| node_pinecone
node_rag_handler -->|"OpenAI embeddings"| node_llm_apis
node_rag_handler -->|"hydrate prices"| node_vtex_apis
node_sync_catalog -->|"walk catalog"| node_vtex_apis
node_sync_catalog -->|"embed (OpenAI)"| node_llm_apis
node_sync_catalog -->|"upsert vectors"| node_pinecone
node_shared_types -.->|"DTOs"| node_widget
node_shared_types -.->|"DTOs"| node_mcp_server
node_shared_types -.->|"DTOs (synced)"| node_service_routes
node_verifier -.->|"GET mandates · receipts · did.json"| node_rest_handlers

